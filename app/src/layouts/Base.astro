---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../data/site';
import { useTranslations, type Locale } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
  /**
   * Root-relative URL of this page in the other locale, or null when no true
   * counterpart exists (hreflang pair is then omitted; the switcher falls back
   * to the other locale's home).
   */
  alternate?: string | null;
  ogImage?: string;
}

const {
  title,
  description,
  locale = 'en',
  alternate = undefined,
  ogImage = '/og-default.png',
} = Astro.props;

const t = useTranslations(locale);
const desc = description ?? t.meta.siteDescription;
const canonical = new URL(Astro.url.pathname, SITE.origin);
const fullTitle = title === SITE.name ? `${SITE.name} — ${t.meta.siteTagline}` : `${title} · ${SITE.name}`;

// hreflang: pure prefix-swap by default; suppressed when alternate === null.
const alternateHref =
  alternate === null
    ? null
    : (alternate ?? (locale === 'en' ? `/it${Astro.url.pathname}` : Astro.url.pathname.replace(/^\/it(\/|$)/, '/')));
const enHref = locale === 'en' ? canonical.pathname : alternateHref;
const itHref = locale === 'it' ? canonical.pathname : alternateHref;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title={SITE.name} href="/rss.xml" />
    {enHref && <link rel="alternate" hreflang="en" href={new URL(enHref, SITE.origin)} />}
    {itHref && <link rel="alternate" hreflang="it" href={new URL(itHref, SITE.origin)} />}
    {enHref && <link rel="alternate" hreflang="x-default" href={new URL(enHref, SITE.origin)} />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, SITE.origin)} />
    <meta name="twitter:card" content="summary_large_image" />
    <script is:inline>
      // Set the theme before first paint to avoid a flash of the wrong theme.
      (() => {
        let theme;
        try {
          theme = localStorage.getItem('theme');
        } catch {}
        if (theme !== 'light' && theme !== 'dark') {
          theme = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        document.documentElement.dataset.theme = theme;
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">{t.a11y.skipToContent}</a>
    <Header locale={locale} alternate={alternateHref} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    inset-inline-start: var(--space-3);
    inset-block-start: var(--space-2);
    z-index: 100;
    background: var(--surface);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-md);
    translate: 0 -300%;
    transition: translate 150ms ease;
  }

  .skip-link:focus {
    translate: 0 0;
  }
</style>
