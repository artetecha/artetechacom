---
import Base from '../layouts/Base.astro';
import { useTranslations } from '../i18n/utils';

const t = useTranslations('en');
---

<Base title={t.notFound.title} locale="en" alternate={null}>
  <div class="container-text wrap">
    <p class="code" aria-hidden="true">404</p>
    <h1>{t.notFound.title}</h1>
    <p class="lede">{t.notFound.body}</p>
    <p><a class="btn btn-primary" href="/">{t.notFound.cta}</a></p>
  </div>
</Base>

<style>
  .wrap {
    text-align: center;
    padding-block: var(--space-7);
  }

  .code {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: 700;
    background: linear-gradient(100deg, var(--slate-400), var(--accent), var(--accent-warm));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin: 0;
  }
</style>
